let a = 1; let b = a + 1;

if (x == 1) {
    let y = x + 2; let yy = x + 4;
    -- 1. Define Static task
    task PythonJob {
        type: "bash"
        command: "./jobSystem"
        schedule: "* * * * *"
    }
} else {
    0;
}

task GolangJob(input_data) {
    type: "internal"
    eval: input_data * 2
}

-- 2. Define DAG
pipeline MainSchedule {
    PythonJob -> GolangJob
}

