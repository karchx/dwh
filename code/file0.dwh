if (x == 1) {
    -- 1. Define Static task
    task PythonJob {
        type: "bash"
        command: "./jobSystem"
        schedule: "* * * * *"
    }
} else {
    0
}

task GolangJob(input_data) {
    type: "internal"
    eval: input_data * 2
}

